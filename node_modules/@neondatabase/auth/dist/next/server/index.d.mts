type TopLevelEndpointKeys<T> = { [K in keyof T]: K }[keyof T];
type ServerAuthMethods = TopLevelEndpointKeys<typeof API_ENDPOINTS>;
type NeonAuthServer = Pick<VanillaBetterAuthClient, ServerAuthMethods>;
